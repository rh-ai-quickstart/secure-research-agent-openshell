# AIQ UI (Next.js) image.
#
# Build from the AIQ source tree:
#   docker build -f Containerfile.ui -t aiq-ui:local /path/to/AIQ/frontends/ui
#
# Or if building from the quickstart repo after cloning AIQ:
#   docker build -f Containerfile.ui -t aiq-ui:local aiq-src/frontends/ui/

FROM node:20-slim AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci --production=false

COPY . .
RUN npm run build

FROM node:20-slim

WORKDIR /app

COPY --from=builder /app/package*.json ./
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/server.js ./server.js

ENV NODE_ENV=production
ENV PORT=3000

EXPOSE 3000

CMD ["node", "server.js"]
