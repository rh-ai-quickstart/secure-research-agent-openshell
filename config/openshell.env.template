# Copy this file to .openshell.env and fill in your API keys.
# This file is git-ignored and should NOT be committed.

OPENSHELL=true

# NVIDIA API key is NOT stored here — it is managed by the OpenShell
# gateway provider via credential isolation. The key is injected by the
# inference routing proxy when the agent calls inference.local.
# Set up with: openshell provider create --name nvidia --type nvidia --credential NVIDIA_API_KEY=nvapi-...

# Tavily API key (required — no inference routing for non-LLM endpoints)
TAVILY_API_KEY=tvly-...

# Proxy for sandbox egress
HTTP_PROXY=http://10.200.0.1:3128
HTTPS_PROXY=http://10.200.0.1:3128

# Application config (uses inference.local for credential isolation)
CONFIG_FILE=/sandbox/config_openshell.yml
HOST=0.0.0.0
PORT=8000
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Trust OpenShell egress proxy ephemeral CA (auto-populated by start-sandbox.sh)
# SSL_CERT_FILE=/sandbox/combined-ca-bundle.pem
# REQUESTS_CA_BUNDLE=/sandbox/combined-ca-bundle.pem
# CURL_CA_BUNDLE=/sandbox/combined-ca-bundle.pem

# Writable state (under /sandbox/data — the only writable path)
NAT_JOB_STORE_DB_URL=sqlite+aiosqlite:////sandbox/data/jobs.db
AIQ_CHROMA_DIR=/sandbox/data/chroma_data
AIQ_CHECKPOINT_DB=/sandbox/data/checkpoints.db
AIQ_SUMMARY_DB=sqlite+aiosqlite:////sandbox/data/summaries.db
